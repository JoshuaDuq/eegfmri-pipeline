    },
    {
      "key": "erds",
      "label": "ERDS",
      "description": "Event-related desynchronization/synchronization"
    },
    {
      "key": "complexity",
      "label": "Complexity",
      "description": "Lempel-Ziv complexity and permutation entropy"
    },
    {
      "key": "spectral",
      "label": "Spectral",
      "description": "Peak frequency, spectral edge, and entropy"
    },
    {
      "key": "ratios",
      "label": "Ratios",
      "description": "Band power ratios (theta/beta, alpha/beta, etc.)"
    },
    {
      "key": "asymmetry",
      "label": "Asymmetry",
      "description": "Hemispheric asymmetry indices"
    },
    {
      "key": "microstates",
      "label": "Microstates",
      "description": "EEG microstate dynamics (coverage, duration, transitions)"
