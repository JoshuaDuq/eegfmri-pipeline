    {
      "id": "behavior_scatter",
      "group": "behavior",
      "label": "Feature-Behavior Scatter",
      "description": "Configurable scatter plots correlating any EEG feature with behavioral columns",
      "required_files": [
        "features_*.tsv",
        "events.tsv"
      ],
      "behavior_plots": [
        "behavior_scatter"
      ],
      "requires_features": true,
      "configurable": {
        "features": {
          "type": "multi_select",
          "label": "Features",
          "description": "EEG features to correlate",
          "options": [
            "power",
            "connectivity",
            "aperiodic",
            "complexity",
            "itpc",
            "pac",
            "erds",
            "spectral",
            "ratios",
            "asymmetry",
            "microstates"
          ],
          "default": [
            "power"
          ]
        },
        "columns": {
          "type": "multi_select_discovered",
          "label": "Behavioral Columns",
          "description": "Columns from events.tsv to correlate with",
          "source": "events_columns",
          "default": [
            "rating"
          ]
        },
        "aggregation_modes": {
          "type": "multi_select",
          "label": "Aggregation",
          "description": "How to aggregate features",
          "options": [
            "roi",
            "global",
            "channel"
          ],
          "default": [
            "roi",
            "global"
          ]
        }
      }
    },
