### Data ###
# Ignore all data by default
eeg_pipeline/data/**
!eeg_pipeline/data/**/.gitkeep

# Allow specific metadata files in bids_output
!eeg_pipeline/data/bids_output/
eeg_pipeline/data/bids_output/**
!eeg_pipeline/data/bids_output/README
!eeg_pipeline/data/bids_output/dataset_description.json
!eeg_pipeline/data/bids_output/participants.tsv
!eeg_pipeline/data/bids_output/participants.json

# Allow specific metadata files in derivatives
!eeg_pipeline/data/derivatives/
eeg_pipeline/data/derivatives/**
!eeg_pipeline/data/derivatives/dataset_description.json

# Allow external data if it exists
!eeg_pipeline/data/external/
!eeg_pipeline/data/external/**

# Specifically ignore common data formats if they escape the data folders
*.fif
*.set
*.fdt
*.nii
*.nii.gz
*.h5
*.npy
*.mat
*.edf
*.bdf
